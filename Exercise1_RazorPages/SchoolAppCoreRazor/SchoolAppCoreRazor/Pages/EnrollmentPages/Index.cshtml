@page
@model SchoolAppCoreRazor.Pages.EnrollmentPages.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Enrollment[0].CourseID)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Enrollment[0].StudentID)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Enrollment[0].Grade)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Enrollment[0].Course)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Enrollment[0].Student)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Enrollment) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.CourseID)
            </td>
            <td>
                @Html.DisplayFor(model => item.StudentID)
            </td>
            <td>
                @Html.DisplayFor(model => item.Grade)
            </td>
            <td>
                @Html.DisplayFor(model => item.Course)
            </td>
            <td>
                @Html.DisplayFor(model => item.Student)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.EnrollmentID">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.EnrollmentID">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.EnrollmentID">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
